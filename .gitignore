# ─── Herramientas externas / dependencias (no son código del proyecto) ───
CSpect/
zxbasic/
*.exe

# ─── Imágenes de disco / medios grandes de emulador ───
*.img
*.iso
*.vhd
*.hdf
*.mp4
*.wav
*.zip

# ─── Artefactos de compilación (se regeneran) ───
build/
dist/
__pycache__/
*.pyc
*.pyo
*.spec
*.fresh

# ─── Juegos: no se sube ninguno (ni datos ni carpetas) ───
Games/

# ─── Ficheros generados por los exportadores (se recrean al compilar) ───
*.loading
*.banks
*.csv
*.png
*.docx
*.md
*.pdf
*.bas
*.bin
*.nxi
*.nxp
*.dsk
*.tap
*.nex
*.sna
*.scr
